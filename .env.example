# AR LEARN — nomes das variáveis de ambiente, sem valores.
# Segredos reais NUNCA entram neste repositório — só nas variáveis de
# ambiente do provedor (Cloudflare Pages / Supabase / GitHub Actions).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API v3 (OAuth do dono do canal)
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Fallback de transcrição
GROQ_API_KEY=

# Geração do JSON estruturado do Learn
OPENROUTER_API_KEY=
# Opcional — modelo barato via OpenRouter. Sem isso, usa o default do
# código (google/gemini-2.5-flash). Alternativa também barata:
# deepseek/deepseek-chat.
OPENROUTER_MODEL=

# Mapa mental (imagem para o PDF) — instância pública, sem conta/chave
KROKI_URL=https://kroki.io

# Voz: Edge TTS (msedge-tts, voz oficial pt-BR-AntonioNeural). Sem
# credencial nenhuma — não precisa de variável de ambiente. Trocado do
# Cloudflare Workers AI/MeloTTS (reprovado por ouvido) em 2026-07-04,
# ver docs/historico.md.

# Pagamento — Mercado Pago é o principal (Pix). Asaas documentado como
# alternativa; nenhum dos dois é implementado antes da Fase 4.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
ASAAS_API_KEY=

# App
NEXT_PUBLIC_SITE_URL=

# ── Phase 3: Altamente Rentável Academy ──────────────────────────────
# Stripe (checkout Pix; conector MCP indisponível na sessão => SDK oficial)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# URL pública do site (success/cancel do checkout)
NEXT_PUBLIC_SITE_URL=
# Vídeo do ep. 171 (Supabase Storage ou CDN; fallback: /videos/... local)
NEXT_PUBLIC_EP171_VIDEO_URL=
# Gate simples do /admin (?token=)
ADMIN_TOKEN=
