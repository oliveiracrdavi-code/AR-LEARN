# AR LEARN — nomes das variáveis de ambiente, sem valores.
# Segredos reais NUNCA entram neste repositório — só nas variáveis de
# ambiente do provedor (Cloudflare Pages / Supabase / GitHub Actions).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API v3 — OAuth do dono do canal (só isso; o código não
# usa uma API key simples separada, todas as chamadas passam pelo
# access token OAuth renovado via refresh_token em lib/youtube/oauth.ts)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Fallback de transcrição
GROQ_API_KEY=

# Geração do JSON estruturado do Learn
OPENROUTER_API_KEY=
# Opcional — modelo barato via OpenRouter. Sem isso, usa o default do
# código (google/gemini-2.5-flash). Alternativa também barata:
# deepseek/deepseek-chat.
OPENROUTER_MODEL=
# Opcional — modelo usado só pra traduzir instrução em linguagem natural
# do admin (ex.: "legenda maior") em generation_config estruturado/
# alterações por Learn. Sem isso, usa google/gemini-2.5-flash-lite
# (mais barato ainda, contexto pequeno o suficiente pra essa tarefa).
OPENROUTER_MODEL_ALTERACOES=

# Mapa mental (imagem para o PDF) — instância pública, sem conta/chave
KROKI_URL=https://kroki.io

# Voz: Edge TTS (msedge-tts, voz oficial pt-BR-AntonioNeural). Sem
# credencial nenhuma — não precisa de variável de ambiente. Trocado do
# Cloudflare Workers AI/MeloTTS (reprovado por ouvido) em 2026-07-04,
# ver docs/historico.md.
#
# Plano C documentado (ver CLAUDE.md/docs/regras.md): Google Cloud TTS,
# pra caso o Edge TTS (API não-oficial, sem SLA) quebrar. Código pronto
# em lib/tts/obsoleto/sintetizarGoogleCloudTts.ts, mas NÃO está
# importado por nenhum caminho ativo hoje — não precisa preencher essas
# duas a menos que o Plano C seja acionado de verdade:
# GOOGLE_CLOUD_TTS_CREDENTIALS_JSON=
# GOOGLE_TTS_VOICE_NAME=

# App
NEXT_PUBLIC_SITE_URL=

# ── Phase 3: Altamente Rentável Academy ──────────────────────────────
# Stripe (checkout Pix; conector MCP indisponível na sessão => SDK oficial)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# URL pública do site (success/cancel do checkout)
NEXT_PUBLIC_SITE_URL=
# Gate do /admin (formulário + cookie httpOnly)
ADMIN_TOKEN=

# ── Cloudflare R2 (storage de vídeo — Ebook/mapa continuam no Supabase) ──
# Gerar em Cloudflare Dashboard → R2 → Manage API Tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ar-learn-videos
# Formato: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
